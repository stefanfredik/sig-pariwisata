APP_NAME="SIG Wisata Manggarai Barat"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://sig.kopiflores.my.id

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=sig_wisata
DB_USERNAME=sig_wisata_user
DB_PASSWORD=sig_wisata_pass

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Docker Compose Configuration
# Customize these ports to avoid conflicts with other applications
COMPOSE_PROJECT_NAME=sig_wisata
NGINX_PORT=8080
MYSQL_PORT=3307
REDIS_PORT=6380
VITE_PORT=5174
DB_ROOT_PASSWORD=root_password

# Cloudflare Tunnel Configuration
# Get your tunnel token from: https://one.dash.cloudflare.com/ -> Networks -> Tunnels
# Leave empty if not using Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=

